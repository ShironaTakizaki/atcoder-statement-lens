{
  "manifest_version": 3,
  "name": "AtCoder Statement Lens",
  "version": "0.1.0",
  "description": "AtCoder の問題文に出てくる変数をマウスオーバーでハイライトします。",
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://atcoder.jp/contests/*/tasks/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
